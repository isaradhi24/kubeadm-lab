pipeline {
    agent any
    environment {
        DOCKER_HUB_USER = 'isaradhi24'
        DOCKER_HUB_REPO = 'kubeadm-lab-java' // Or your preferred repo name
        GIT_REPO_URL    = 'https://github.com/isaradhi24/kubeadm-lab.git'
    }
    stages {
        stage('Checkout') {
    steps {
        checkout([$class: 'GitSCM', 
            branches: [[name: '*/main']], 
            extensions: [], 
            userRemoteConfigs: [[
                credentialsId: 'GitHub_ID', 
                url: 'https://github.com/isaradhi24/kubeadm-lab.git'
            ]]
        ])
    }
}
        stage('Build Docker Image') {
            steps {
                echo "Building Docker image after webhook configuered"
                script {
                    sh "pwd"
                    sh "ls -l apps/Microservices-app/Microservice1"

                    // Moving the variable inside a script block makes it valid Groovy
                    def appPath = "apps/Microservices-app/Microservice1"
                    
                    sh "docker build -t ${DOCKER_HUB_USER}/${DOCKER_HUB_REPO}:${env.BUILD_NUMBER} -f ${appPath}/Dockerfile ${appPath}"
                    sh "docker tag ${DOCKER_HUB_USER}/${DOCKER_HUB_REPO}:${env.BUILD_NUMBER} ${DOCKER_HUB_USER}/${DOCKER_HUB_REPO}:latest"
                }
            }
        }
        stage('Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'DockerHub_ID', passwordVariable: 'PASS', usernameVariable: 'USER')]) {
                    sh "echo \$PASS | docker login -u \$USER --password-stdin"
                    sh "docker push ${DOCKER_HUB_USER}/${DOCKER_HUB_REPO}:${env.BUILD_NUMBER}"
                    sh "docker push ${DOCKER_HUB_USER}/${DOCKER_HUB_REPO}:latest"
                }
            }
        }
        stage('Update Git Manifest') {
            steps {
                script {
                // Using credentials for the git push
                withCredentials([usernamePassword(credentialsId: 'GitHub_ID', passwordVariable: 'GIT_PASS', usernameVariable: 'GIT_USER')]) {
        
                // 1. Fetch all branches and switch to main properly
                sh "git fetch origin"
                sh "git checkout main || git checkout -b main"
                sh "git pull origin main"

                // 2. Update the image version
                def deploymentPath = "apps/Microservices-app/Microservice1/deployment.yaml"
                sh "sed -i 's|image: .*:.*|image: ${DOCKER_HUB_USER}/${DOCKER_HUB_REPO}:${env.BUILD_NUMBER}|' ${deploymentPath}"

                // 3. Commit and Push
                sh "git config user.email 'jenkins@example.com'"
                sh "git config user.name 'Jenkins CI'"
                sh "git add ${deploymentPath}"
                sh "git commit -m 'Jenkins Build #${env.BUILD_NUMBER}: Update image' || echo 'No changes to commit'"
        
                // Use the authenticated URL
                sh "git push https://${GIT_USER}:${GIT_PASS}@github.com/${GIT_USER}/kubeadm-lab.git main"
                }
            }
        }
   }
 }   
}