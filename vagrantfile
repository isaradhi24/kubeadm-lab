#==========================================================
# Vagrantfile: Production-Grade Kubernetes Lab (FULL VERSION)
# Fixed for SSH Timeouts and Reintegrated All Services
#==========================================================
#==========================================================
# Vagrantfile: Production-Grade Kubernetes Lab (Validated)
# Fixes: SSH Key Handshake, WinNAT Timeouts, & K8s v1.29
#==========================================================
#==========================================================
# Vagrantfile: Production-Grade Kubernetes Lab (STABLE)
#==========================================================

Vagrant.configure("2") do |config|

  config.vm.box = "bento/ubuntu-22.04"
  ENV["VAGRANT_NO_PARALLEL"] = "yes"

  # --- GLOBAL SSH CONFIGURATION (FIXED) ---
  config.ssh.username = "vagrant"
  config.ssh.password = "vagrant"
  config.ssh.insert_key = false
  
  # This tells Vagrant to allow password auth if keys fail without using the 'auth_methods' key
  config.ssh.keys_only = false 
  
  config.vm.boot_timeout = 900

  NODES = {
    "k8s-master"  => { ip: "192.168.56.10", ram: 4096, cpus: 2, role: "master" },
    "k8s-worker1" => { ip: "192.168.56.11", ram: 1536, cpus: 1, role: "worker" },
    "jenkins-ci"  => { ip: "192.168.56.20", ram: 2048, cpus: 2, role: "manual" },
    "sonarqube"   => { ip: "192.168.56.30", ram: 4096, cpus: 2, role: "manual" }
  }

  NODES.each do |name, opts|
    config.vm.define name do |node|

      node.vm.hostname = name
      node.vm.network "private_network", ip: opts[:ip]
      node.vm.network "forwarded_port", guest: 8080, host: 8080, auto_correct: true

      node.vm.provider "virtualbox" do |vb|
        vb.name = name
        vb.memory = opts[:ram]
        vb.cpus = opts[:cpus]
        vb.customize ["modifyvm", :id, "--natdnshostresolver1", "on"]
        vb.customize ["modifyvm", :id, "--cableconnected1", "on"]
      end
      
      if name == "k8s-worker1"
        node.trigger.before :up do |t|
          t.run = { inline: "vagrant up k8s-master" }
        end
      end

      if opts[:role] == "master"
        node.vm.synced_folder "D:/Devops/kubeadm-lab/manifests", "/home/vagrant/manifests"
      end

      node.vm.provision "shell", privileged: true, inline: <<-SHELL
        set -e
        # Fix SSH for Ubuntu 22.04 keys
        if ! grep -q "PubkeyAcceptedKeyTypes +ssh-rsa" /etc/ssh/sshd_config; then
          echo "PubkeyAcceptedKeyTypes +ssh-rsa" >> /etc/ssh/sshd_config
          systemctl restart ssh
        fi

        if [ "#{opts[:role]}" != "manual" ]; then
          echo "==== Provisioning K8s Node: #{name} ===="
          sudo swapoff -a
          sudo sed -i '/swap/d' /etc/fstab
          echo -e "overlay\\nbr_netfilter" | sudo tee /etc/modules-load.d/k8s.conf
          sudo modprobe overlay
          sudo modprobe br_netfilter
          echo -e "net.bridge.bridge-nf-call-iptables=1\\nnet.bridge.bridge-nf-call-ip6tables=1\\nnet.ipv4.ip_forward=1" | sudo tee /etc/sysctl.d/k8s.conf
          sudo sysctl --system

          sudo apt-get update -y
          sudo apt-get install -y containerd curl gnupg apt-transport-https ca-certificates
          sudo mkdir -p /etc/containerd
          sudo containerd config default | sed 's/SystemdCgroup = false/SystemdCgroup = true/' | sudo tee /etc/containerd/config.toml
          sudo systemctl restart containerd

          sudo mkdir -p /etc/apt/keyrings
          curl -fsSL https://pkgs.k8s.io/core:/stable:/v1.29/deb/Release.key | sudo gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg
          echo "deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.29/deb/ /" | sudo tee /etc/apt/sources.list.d/kubernetes.list
          sudo apt-get update -y
          sudo apt-get install -y kubelet kubeadm kubectl
          sudo apt-mark hold kubelet kubeadm kubectl
          echo "KUBELET_EXTRA_ARGS=--node-ip=#{opts[:ip]}" | sudo tee /etc/default/kubelet
          sudo systemctl enable --now kubelet
        fi

        echo "vagrant ALL=(ALL) NOPASSWD:ALL" | sudo tee /etc/sudoers.d/vagrant

        if [ "#{opts[:role]}" = "master" ]; then
          sudo kubeadm init --apiserver-advertise-address=#{opts[:ip]} --pod-network-cidr=10.244.0.0/16 --ignore-preflight-errors=all
          mkdir -p /home/vagrant/.kube
          sudo cp /etc/kubernetes/admin.conf /home/vagrant/.kube/config
          sudo chown -R vagrant:vagrant /home/vagrant/.kube
          su - vagrant -c "kubectl apply -f https://raw.githubusercontent.com/projectcalico/calico/v3.27.0/manifests/calico.yaml"
          sudo kubeadm token create --print-join-command > /vagrant/kube_join.sh
        fi

        if [ "#{opts[:role]}" = "worker" ]; then
          while [ ! -f /vagrant/kube_join.sh ]; do sleep 10; done
          bash /vagrant/kube_join.sh
        fi
      SHELL

      # (Jenkins-ci block)
      if name == "jenkins-ci"
        node.vm.synced_folder "./jenkins_home", "/var/lib/jenkins_home"
        node.vm.synced_folder "./pipelines", "/var/lib/jenkins_home/pipelines"
        node.vm.synced_folder "./docker_home", "/var/docker_home"
        node.vm.provision "shell", path: "scripts/install_docker.sh"
        node.vm.provision "shell", path: "scripts/config_docker.sh"
        node.vm.provision "shell", path: "scripts/install_jenkins.sh"
        node.vm.provision "shell", path: "scripts/plugins_jenkins.sh"
        node.vm.provision "shell", path: "scripts/config_jenkins.sh"
        
        # Add the PAT reading logic here
        pat_file = "./secrets/git-persona-access-token"
        github_token = File.exist?(pat_file) ? File.read(pat_file).strip : "TOKEN_NOT_FOUND"

        node.vm.provision "shell", inline: <<-SHELL
          # 1. Set the JCasC Path (Your existing logic)
          sudo sed -i '/jenkins.casc.configuration/d' /etc/environment
          echo "jenkins.casc.configuration='/var/jenkins_home/casc_configs/jenkins.yaml'" | sudo tee -a /etc/environment
          
          # 2. Set the GitHub PAT (New logic)
          sudo sed -i '/GITHUB_PAT/d' /etc/environment
          echo "GITHUB_PAT=#{github_token}" | sudo tee -a /etc/environment
          
          # 3. Restart Jenkins once to pick up BOTH variables
          sudo systemctl restart jenkins
        SHELL
      end
      
    # (Sonar block remain unchanged)
      if name == "sonarqube"
        node.vm.synced_folder "./sonarqube_home", "/var/sonarqube_home"
        node.vm.provision "shell", path: "scripts/install_sonarqube.sh"
        node.vm.provision "shell", path: "scripts/config_sonarqube.sh"
      end
    
      # Put this inside the NODES.each loop, right after the Jenkins/Sonar blocks
      node.vm.provision "Post-Setup", type: "shell", privileged: true, inline: <<-SHELL
        if [ "#{opts[:role]}" = "master" ]; then
          echo "Waiting for K8s API..."
          export KUBECONFIG=/home/vagrant/.kube/config
          until kubectl get nodes; do sleep 5; done
          
          echo "Ensuring Namespaces..."
          kubectl create namespace nginx-ns --dry-run=client -o yaml | kubectl apply -f -
          
          echo "Cleaning up old port-forwards..."
          pkill -f "port-forward" || true
          
          # Only run port-forward if ArgoCD is actually installed
          if kubectl get svc argocd-server -n argocd > /dev/null 2>&1; then
             nohup kubectl port-forward --address 0.0.0.0 svc/argocd-server -n argocd 8443:443 > /home/vagrant/argocd-tunnel.log 2>&1 &
             echo "ArgoCD Tunnel Started on Port 8443"
          fi
        fi
      SHELL
    
      # ==========================================================
      # THE "SANITY SAVER" AUTOMATION (MOVED INSIDE THE LOOP)
      # ==========================================================
      # node.trigger.after :up do |trigger|
      #   trigger.name = "Final Infrastructure Setup"
      #   trigger.run = { inline: <<-SHELL
      #     if [ "#{opts[:role]}" = "master" ]; then
      #       echo "--- Waking up Kubernetes (Master) ---"
      #       for i in {1..30}; do
      #         if kubectl --kubeconfig=/home/vagrant/.kube/config get nodes >/dev/null 2>&1; then break; fi
      #         echo "Waiting for API... ($i/30)"
      #         sleep 5
      #       done
      #       kubectl --kubeconfig=/home/vagrant/.kube/config create namespace nginx-ns --dry-run=client -o yaml | kubectl --kubeconfig=/home/vagrant/.kube/config apply -f -
            
      #       echo "--- Starting ArgoCD Tunnel ---"
      #       sudo pkill -f "port-forward" || true
      #       nohup kubectl --kubeconfig=/home/vagrant/.kube/config port-forward --address 0.0.0.0 svc/argocd-server -n argocd 8443:443 > /home/vagrant/argocd-tunnel.log 2>&1 &
      #       echo "READY: ArgoCD -> https://192.168.56.10:8443"
      #     fi

      #     if [ "#{name}" = "jenkins-ci" ]; then
      #       echo "--- Checking Jenkins CI ---"
      #       until curl -s -o /dev/null -w "%{http_code}" http://localhost:8080/login | grep -q "200"; do sleep 5; done
      #       echo "READY: Jenkins -> http://192.168.56.20:8080"
      #     fi
      #     echo "=========================================================="
      #   SHELL
      #   }
      # end

    end # This closes 'config.vm.define'
  end # This closes 'NODES.each'
end # This closes 'Vagrant.configure'